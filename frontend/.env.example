# Dev proxy target (Vite server.proxy). Defaults in vite.config.js if unset.
# Same machine (yarn dev + backend on :3000):
# VITE_PROXY_TARGET=http://127.0.0.1:3000
# Full stack Docker; service name "backend" on same compose network:
# VITE_PROXY_TARGET=http://backend:3000
# Remote API:
# VITE_PROXY_TARGET=http://13.51.175.203

# Optional: set false if proxy target uses HTTPS with a self-signed cert
# VITE_PROXY_SECURE=false
